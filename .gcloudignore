# Version Control
.git/
.github/
.gitignore

# IDE & OS Files
.idea/
.vscode/
.DS_Store
Thumbs.db

# ------------------------------------------------------------------------------
# BUILD ARTIFACTS & DEPENDENCIES
# We exclude these so Cloud Build starts "fresh" and doesn't upload megabytes of trash.
# ------------------------------------------------------------------------------
**/node_modules/
**/target/
**/dist/
**/build/
**/coverage/
**/.next/
**/.nuxt/

# ------------------------------------------------------------------------------
# SECURITY & INFRASTRUCTURE
# Crucial: Never upload local state or secrets to the build environment.
# ------------------------------------------------------------------------------
**/.terragrunt-cache/
**/.terraform/
**/*.tfstate
**/*.tfstate.backup
**/*.tfvars
**/*.tfvars.json
**/.env
**/.env.local
**/.env.*.local
**/*.pem
**/*.key

# ------------------------------------------------------------------------------
# LOGS
# ------------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*